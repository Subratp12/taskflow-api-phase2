# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow API — Environment Configuration
# Copy this file to .env and fill in values before running the application.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
FLASK_ENV=development                   # development | staging | production
APP_VERSION=1.0.0                       # Injected at build time (match Docker image tag)
PORT=5000                               # Application port
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change-me-to-a-random-256-bit-secret

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taskflow:taskflow_pass@localhost:5432/taskflow
DB_POOL_SIZE=5                          # Connections kept open
DB_MAX_OVERFLOW=10                      # Extra connections when pool is full
DB_POOL_TIMEOUT=30                      # Seconds to wait for a connection
DB_POOL_RECYCLE=1800                    # Recycle connections after 30 min (prevents stale)

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-256-bit-secret
JWT_ACCESS_TOKEN_MINUTES=30             # Short-lived access token
JWT_REFRESH_TOKEN_DAYS=7               # Long-lived refresh token

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=100 per minute        # Global default rate limit
REDIS_URL=memory://                     # Use redis://host:6379/0 in production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev only.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_LOG_ROUNDS=12                    # Cost factor (use 4 in dev, 12-14 in prod)

# ── Gunicorn (production) ─────────────────────────────────────────────────────
GUNICORN_WORKERS=4                      # Usually (2 × CPU cores) + 1
GUNICORN_TIMEOUT=30

# ── Testing ───────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://taskflow:taskflow_pass@localhost:5432/taskflow_test
